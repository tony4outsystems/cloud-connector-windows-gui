{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Cloud Connector GUI",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build gui",
      "program": "${workspaceFolder}/src/cloud-connector-gui/bin/Debug/net10.0/cloud-connector-gui",
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "internalConsole",
      "windows": {
        "program": "${workspaceFolder}/src/cloud-connector-gui/bin/Debug/net10.0/cloud-connector-gui.exe"
      },
      "osx": {
        "env": {
          "DOTNET_ROOT": "/opt/homebrew/opt/dotnet/libexec",
          "DOTNET_ROOT_ARM64": "/opt/homebrew/opt/dotnet/libexec"
        }
      }
    }
  ]
}
